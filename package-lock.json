{
  "name": "ai-context-os-monorepo",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "ai-context-os-monorepo",
      "workspaces": [
        "packages/*"
      ],
      "engines": {
        "node": ">=18"
      }
    },
    "node_modules/@context-os/eval": {
      "resolved": "packages/eval",
      "link": true
    },
    "node_modules/@context-os/schemas": {
      "resolved": "packages/schemas",
      "link": true
    },
    "node_modules/context-os": {
      "resolved": "packages/cli",
      "link": true
    },
    "packages/cli": {
      "name": "context-os",
      "version": "0.1.0",
      "license": "MIT",
      "dependencies": {
        "@context-os/eval": "0.1.0"
      },
      "bin": {
        "context-os": "bin/context-os.mjs"
      },
      "engines": {
        "node": ">=18"
      }
    },
    "packages/eval": {
      "name": "@context-os/eval",
      "version": "0.1.0",
      "license": "MIT",
      "bin": {
        "context-os-eval": "bin/run-eval.mjs"
      },
      "engines": {
        "node": ">=18"
      }
    },
    "packages/schemas": {
      "name": "@context-os/schemas",
      "version": "0.1.0",
      "license": "MIT"
    }
  }
}
